# ─────────────────────────────────────────────────────────────────────────────
# Healthcare M&A Diligence Platform — environment configuration
#
# The MVP demo runs WITHOUT any of these values (it uses the seed-backed data
# layer). They are the seams for wiring production services in later phases.
# ─────────────────────────────────────────────────────────────────────────────

# Data layer: "seed" (default, in-memory demo) or "supabase"
DATA_BACKEND=seed

# ── Supabase (live: persistence + SharePoint Edge Function) ──────────────────
# The anon key is publishable (it ships in the client bundle). The GitHub Pages
# deploy bakes these in via the build workflow.
NEXT_PUBLIC_SUPABASE_URL=https://gyligrsjpvniupfvczqb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SharePoint access passcode: entered by the user in the app (Settings / Data Rooms),
# never an env var on the frontend. The Edge Function checks its SHA-256, set as the
# function secret APP_ACCESS_KEY_SHA256 (or the in-code default).

# ── Microsoft Entra ID / Graph (Phase 2: SharePoint + Outlook) ───────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_ROOT_FOLDER=M&A Data Rooms

# ── AI (Phase 3: classification, extraction, assistant) ──────────────────────
# Use Azure OpenAI under a signed BAA for PHI-bearing documents.
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
